# Evaluation data and generated artefacts stay out of git.
# PDFs are copyrighted and must NEVER be committed/pushed — ignore them anywhere under eval/.
*.pdf
**/*.pdf

# curated gold data and generated outputs
*/gold/*.json
*/runs/*
*/report/*
*/memory.md
*/best_prompt.txt
*/gold_review.*
*/gold_corrections*.json

# local helper lists
MISSING_PDFS.txt
PDFS_TO_DOWNLOAD.*

# keep the directory structure, docs and per-topic overrides
!*/gold/.gitkeep
!*/pdfs/.gitkeep
!*/profile.json

# DO commit the per-iteration results: matplotlib trend figures + metrics CSV
# (these are the paper artefacts and the archived progression — not raw data)
!*/results/
!*/results/*.csv
!*/results/*.png
!*/results/*.pdf
